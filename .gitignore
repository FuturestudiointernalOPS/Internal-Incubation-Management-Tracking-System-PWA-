# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
impactos_production_env_vars.txt

# vercel
.vercel

# database
local.db
data.json

# finance (local Excel file — do not commit)
/finance/*.xlsx

# typescript
*.tsbuildinfo
next-env.d.ts

nul

CLAUDE.md

# graphify extraction cache (regenerated by majkevgraph.sh / graphify_rebuild.py, not the graph output itself)
src/graphify-out/
graphify-out/cache/
graphify-out-full/cache/
